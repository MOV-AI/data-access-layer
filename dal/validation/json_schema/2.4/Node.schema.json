{
    "$id": "node.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$version": "2.4",
    "title": "Node Schema",
    "definitions": {
        "portfields": {
            "Description": "define the port fields of in/out ports of the Node",
            "type": "object",
            "properties": {
                "Message": {
                    "type": "string"
                },
                "Callback": {
                    "type": "string"
                },
                "Parameter": {
                    "type": "object",
                    "properties": {
                        "Child": {
                            "type": "string"
                        },
                        "Parent": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "actionFields": {
            "cancel": {
                "$ref": "#/definitions/portfields"
            },
            "feedback": {
                "$ref": "#/definitions/portfields"
            },
            "goal": {
                "$ref": "#/definitions/portfields"
            },
            "status": {
                "$ref": "#/definitions/portfields"
            },
            "result": {
                "$ref": "#/definitions/portfields"
            }
        }
    },
    "type": "object",
    "properties": {
        "Title": {
            "type": "string"
        },
        "Label": {
            "type": "string",
            "pattern": "^[a-zA-Z\\.0-9_-]+$"
        },
        "User": {
            "type": "string"
        },
        "Info": {
            "type": "string"
        },
        "LastUpdate": {
            "type": ["object", "string"],
            "properties": {
                "date": {
                    "type": "string"
                },
                "user": {
                    "type": "string"
                }
            },
            "required": [
                "user",
                "date"
            ]
        },
        "InstallPath": {
            "type": "string"
        },
        "Version": {
            "type": "string"
        },
        "VersionDelta": {
            "type": "object"
        },
        "EnvVar": {
            "$ref": "common/arg.schema.json"
        },
        "CmdLine": {
            "$ref": "common/arg.schema.json"
        },
        "Parameter": {
            "$ref": "common/arg.schema.json"
        },
        "Launch": {
            "type": [
                "boolean",
                "string"
            ]
        },
        "PackageDepends": {
            "type": [
                "string",
                "array"
            ]
        },
        "Path": {
            "type": "string"
        },
        "Persistent": {
            "type": "boolean"
        },
        "PortsInst": {
            "type": "object",
            "patternProperties": {
                "^[a-zA-Z0-9_]+$": {
                    "type": "object",
                    "properties": {
                        "Message": {
                            "type": "string"
                        },
                        "Package": {
                            "type": "string"
                        },
                        "Template": {
                            "type": "string"
                        },
                        "Out": {
                            "allOf": [
                                {
                                    "type": "object",
                                    "properties": {
                                        "out": {
                                            "$ref": "#/definitions/portfields"
                                        }
                                    }
                                },
                                {
                                    "$ref": "#/definitions/actionFields"
                                }
                            ]
                        },
                        "In": {
                            "allOf": [
                                {
                                    "type": "object",
                                    "properties": {
                                        "in": {
                                            "$ref": "#/definitions/portfields"
                                        }
                                    }
                                },
                                {
                                    "$ref": "#/definitions/actionFields"
                                }
                            ]
                        }
                    },
                    "required": [
                        "Message",
                        "Package",
                        "Template"
                    ]
                }
            },
            "minProperties": 1
        },
        "Remappable": {
            "type": ["boolean", "string"]
        },
        "Type": {
            "type": "string",
            "enum": ["ROS1/Node","ROS1/Plugin", "MovAI/Node", "MovAI/State", "MovAI/Server", "ROS2/Node", "ROS2/Launch"]
        }
    },
    "unevaluatedProperties": false
}
